{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebSearch",
      "Bash([ -f \"$F\" ])",
      "Bash(python -m ruff check src tests --statistics)",
      "Bash(python -m ruff check src tests --select F)",
      "Bash(python -m ruff check src tests --fix)",
      "Bash(python -m ruff check src tests)",
      "Bash(python -m ruff check src tests --select E501 --output-format concise)",
      "Bash(python -m mypy src/vflank/core src/vflank/io)",
      "Bash(python -m pytest -q)",
      "Bash(python -m ruff check src --select F841)",
      "Bash(grep -rn \"TODO\\\\|FIXME\\\\|raise NotImplementedError\\\\|\\\\.\\\\.\\\\.$\" src)",
      "Bash(exit 1)",
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git commit -q -m ' *)"
    ]
  }
}
